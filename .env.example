# Copia questo file in `.env` e riempi con i valori del TUO progetto Supabase.
# Il file `.env` è ignorato da Git (vedi .gitignore) — non committare mai le chiavi.
#
# Dove trovarli: Supabase Dashboard -> Project Settings -> API Keys
#   - "API URL" (o "Project URL")       -> VITE_SUPABASE_URL
#   - Publishable key (sb_publishable_) -> VITE_SUPABASE_PUBLISHABLE_KEY
#
# USA LA PUBLISHABLE KEY (sb_publishable_...), non la secret (sb_secret_...):
# la secret bypassa le RLS e non deve MAI stare nel client.
# (Le vecchie chiavi anon/service_role funzionano ancora ma sono in dismissione.)
#
# La publishable key è pensata per il client. A proteggere i dati sono le
# Row-Level Security policy definite in docs/schema.sql, non il segreto.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
